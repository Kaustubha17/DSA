package Weekly_Contest_318;

import java.util.ArrayList;

public class StringOperations {
	public static int solve(int N, String s){
		int count=0;
		ArrayList<String>vowels=new ArrayList<>();
		vowels.add("a");
		vowels.add("e");
		vowels.add("i");
		vowels.add("o");
		vowels.add("u");
		for(int i=0;i<N;i++) {
			String a=s.substring(i, i+1);
			String b="";
			if(i<N-1)
			{
				b=s.substring(i+1, i+2);
				if(vowels.contains(a)&&vowels.contains(b))
					count+=1;
				else if(!vowels.contains(a)&&!vowels.contains(b))
					count+=1;
			
			}
		}
		
		return count;
    }
	public static void main(String[] args) {
		System.out.println(solve(4,"wlrb"));

	}

}
