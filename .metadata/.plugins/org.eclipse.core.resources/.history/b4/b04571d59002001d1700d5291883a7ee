import java.util.Scanner;

public class DiamondStar {

	public static void main(String[] args) {

		Scanner s=new Scanner(System.in);
		int n=s.nextInt();

		int i=1;
		while(i<n) {

			if(i<=((n+1)/2)) {

				int spaces=1;

				while(spaces<=n-(i+2)) {
					System.out.print(" ");
					spaces++;
				}

				int stars=1;
				while(stars<=i) {
					System.out.print("*");
					stars++;
				}
				int secondStars=i-1;
				while(secondStars>=1) {
					System.out.print("*");
					secondStars--;

				}
				System.out.println();
				i++;
			}

			else { 
				
				int spaces=1;

				while(spaces<=-(n-(i+2))) {
					System.out.print(" ");
					spaces++;
				}

				int stars=1;
				while(stars<=(n-i+1)) {
					System.out.print("*");
					stars++;
				}
				
				
				
				
				
				
				
				i++;
			}
			
		
		}


	}

}
