package Weekly_Contest_318;

import java.util.ArrayList;

public class StringOperations {
	public static int solve(int N, String s){
		int count=0;
		ArrayList<String>vowels=new ArrayList<>();
		vowels.add("a");
		vowels.add("e");
		vowels.add("i");
		vowels.add("o");
		vowels.add("u");
		ArrayList<String>string=new ArrayList<>();
		for(int i=0;i<s.length();i++) {
			string.add(s.substring(i,i+1));
		}
		
		for(int i=0;i<N-1;i++) {
			String a=string.get(i);
			String b=string.get(i+1);
			
			if(vowels.contains(a)&&vowels.contains(b)) {
					count+=1;
					if(i-1>=0 && vowels.contains(string.get(i-1)) )
						string.set(i, "c");
					else
					string.set(i+1, "c");
				
				}
				else if(!vowels.contains(a)&&!vowels.contains(b)) {
					count+=1;
					if(i-1>=0 && !vowels.contains(string.get(i-1)) )
						string.set(i, "a");
					else
				string.set(i+1, "a");
				
			}
		}
		for(String a:string) {
			System.out.print(a);
		}
		return count;
    }
	public static void main(String[] args) {
		System.out.println(solve(3,"owf"));

	}

}
