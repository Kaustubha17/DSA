import java.util.Scanner;

public class IsoscelesTriangle {

	public static void main(String[] args) {
		Scanner s=new Scanner(System.in);
		int n=s.nextInt();
		int i=1;
		while(i<=n) {
			int j=1;
//			First loop for placing spaces
			while(j<=n-i) {
				System.out.print(" ");
				j++;
			}
			j=1;
//			Second loop to place stars
			while(j<=i) {
				System.out.print("*");
				j++;
			}
		System.out.println();
		i++;
	}
	}

}
