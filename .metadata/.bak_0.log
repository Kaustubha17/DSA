import java.util.Arrays;

public class Magic_Grid {
	
public static int getMinimumStrength(int[][] grid,int i,int j,int visited[][]) {
        if(i<0||i>=grid.length||j<0||j>=grid[0].length)
        	return 0;
        if(visited[i][j]!=Integer.MIN_VALUE)
        	return visited[i][j];
        
        int down=getMinimumStrength(grid, i+1, j,visited);
        int right=getMinimumStrength(grid, i, j+1,visited);
        

        return grid[i][j]+Math.max(down, right);

    }

public static int getMinimumStrength(int[][] grid,int i,int j) {
    if(i<0||i>=grid.length||j<0||j>=grid[0].length)
    	return 0;
    
    int down=getMinimumStrength(grid, i+1, j);
    int right=getMinimumStrength(grid, i, j+1);
    

    (grid[i][j]+Math.max(down, right);

}

	public static void main(String[] args) {
int grid[][]= {
		{0 ,1 ,-3},
		{1, -2, 0}
};
	int visited[][]=new int[grid.length][grid[0].length];
	for(int i=0;i<visited.length;i++)
		Arrays.fill(visited[i], Integer.MIN_VALUE);
System.out.println(getMinimumStrength(grid, 0, 0,visited));
	}

}

