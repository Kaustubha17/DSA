import java.util.*;
public class PairSum {
	
	
	 public static int consecutivePairs(int []arr,int i,int j){
	        int firstElem=i+1;
	        int firstElemCounter=1;
	        int lastElem=j;
	        int lastElemCounter=1;
	        while(firstElem<=j && arr[firstElem]==arr[i]){
	            firstElemCounter++;
	            firstElem++;
	            
	        }
	        System.out.println("firstElem: "+firstElem);
	        
	        if(firstElem==j)
	        {
	            return firstElemCounter;
	        }
	        
	        while(lastElem>=i && arr[lastElem]==arr[j]){
	            lastElem--;
	            lastElemCounter++;
	        }
	        firstElem*lastElemCounter
	        
	        return firstElem*lastElemCounter;
	    }
	    public static int duplicateStart(int arr[],int i){
	        int counter=0;
	        int start=i;
	        while(start<arr.length && arr[start]==arr[i]){
	            counter++;
	            start++;
	        }
	        return counter;
	    }
	    
	        public static int duplicateEnd(int arr[],int j){
	        int counter=0;
	        int end=j;
	        while(arr[end]==arr[j] && end>=0){
	            counter++;
	            end--;
	        }
	        return counter;
	    }
	    
	    
		public static int pairSum(int[] arr, int num) {
	Arrays.sort(arr);
	for(int i:arr)
		System.out.print(i+" ");
	System.out.println();
	        int i=0;
	        int j=arr.length-1;
	        int counter=0;
	        while(i<j){
	            if((arr[i]+arr[j])<num){
	                i++;
	            }
	            else if((arr[i]+arr[j])>num){
	                j--;
	            }
	            else{     
	            	counter+=consecutivePairs(arr,i,j);
	            int startJump=duplicateStart(arr,i);
                int endJump=duplicateEnd(arr,j);
                i=i+startJump;
                j=j-endJump;
	              
	           
	                
	                
	            }
	        }
	        
	return counter/2;        
	        
		}

	public static void main(String[] args) {
int arr[]= {0,6,0,0};


System.out.println(pairSum(arr,6));
		
	}

}

