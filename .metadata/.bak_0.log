public class Apply_Operations_to_an_Array {

    public int[] applyOperations(int[] nums) {
        for(int i=0;i<nums.length-1;i++) {
        	if(nums[i]==nums[i+1]) {
        		nums[i]=2*nums[i];
        		nums[i+1]=0;
        	}
        }
        
        
        int snowBallSize=0;
       for(int i=0;i<nums.length;i++) {
